# AI enrichment (OpenAI-compatible API)
# Works with OpenAI, LM Studio, Ollama, or any OpenAI-compatible endpoint.
#
# Cloud provider (OpenAI, OpenRouter, etc.):
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=***
#   AI_MODEL=gpt-4o-mini
#
# Local LM Studio provider (qwen/qwen3.5-9b or qwen/qwen3-14b recommended):
#   AI_BASE_URL=http://localhost:1234/v1
#   AI_API_KEY=*** leave blank for LM Studio
#   AI_MODEL=qwen/qwen3.5-9b
#   LINK_CURATOR_MAX_TOKENS=2048
#   LINK_CURATOR_REQUEST_TIMEOUT_MS=60000
#   LINK_CURATOR_DISABLE_REASONING=true
#
# LINK_CURATOR_DISABLE_REASONING uses a /no_think prompt prefix that
# prevents Qwen models from wasting tokens on hidden reasoning. Pair
# with LM Studio's "Disable thinking" model setting for best results.
#
# AI config is optional. Without AI_BASE_URL + AI_MODEL, links still
# save locally with fetched metadata. Retry enrichment later via UI.

# Obsidian vault export
# LINK_CURATOR_OBSIDIAN_VAULT=/Users/damoncook/AI/obsidian/Hermes
# LINK_CURATOR_EXPORT_SUBDIR=Inbox
