<div class="form-group">
  <input type="url" id="link-url" placeholder="Paste a URL..." required />
  <button id="link-submit">Save</button>
</div>
<div class="status-bar" id="link-status"></div>

<script>
  const input = document.getElementById('link-url') as HTMLInputElement | null;
  const btn = document.getElementById('link-submit') as HTMLButtonElement | null;
  const status = document.getElementById('link-status') as HTMLDivElement | null;

  if (input && btn && status) {
    btn.addEventListener('click', async () => {
      const url = input.value.trim();
      if (!url) return;

      btn.disabled = true;
      status.textContent = 'Saving...';
      status.className = 'status-bar loading-text';

      try {
        const res = await fetch('/api/links', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url }),
        });

        if (!res.ok) {
          const err = await res.json();
          status.textContent = err.error || 'Failed to save link';
          status.className = 'status-bar error-text';
          btn.disabled = false;
          return;
        }

        status.textContent = 'Saved!';
        status.className = 'status-bar success-text';
        input.value = '';
        setTimeout(() => window.location.reload(), 600);
      } catch {
        status.textContent = 'Network error';
        status.className = 'status-bar error-text';
        btn.disabled = false;
      }
    });
  }
</script>
