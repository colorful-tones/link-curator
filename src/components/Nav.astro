---
const currentPath = Astro.url.pathname;

function isActive(path: string): string {
  if (path === '/' && currentPath === '/') return 'nav-active';
  if (path !== '/' && currentPath.startsWith(path)) return 'nav-active';
  return '';
}
---

<nav class="site-nav">
  <a href="/" class={`nav-link ${isActive('/')}`}>List</a>
  <a href="/calendar" class={`nav-link ${isActive('/calendar')}`}>Calendar</a>
  <a href="/graph" class={`nav-link ${isActive('/graph')}`}>Graph</a>
</nav>

<style>
  .site-nav {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .nav-link {
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .nav-link:hover {
    background: var(--color-surface-raised);
    color: var(--color-text);
    text-decoration: none;
  }
  .nav-active {
    background: var(--color-tag-bg);
    color: var(--color-primary);
  }
</style>
