---
import { getEntryById } from '../../lib/db';
import '../../styles/global.css';

const { id } = Astro.params;
const entry = id ? getEntryById(id) : null;

if (!entry) {
  return Astro.redirect('/');
}

const domain = new URL(entry.url).hostname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{entry.title || 'Link'} - Link Curator</title>
  </head>
  <body>
    <div class="container">
      <header class="app-header">
        <h1><a href="/">Link Curator</a></h1>
      </header>

      <div class="detail-card">
        <h1>{entry.title || entry.url}</h1>

        <div class="card-meta">
          <a href={entry.url} target="_blank" rel="noopener noreferrer">{domain}</a>
          {entry.siteName ? <span> &middot; {entry.siteName}</span> : null}
          {entry.contentType !== 'other' ? <span> &middot; {entry.contentType}</span> : null}
          {entry.status === 'failed' ? <span class="badge-failed">failed</span> : null}
          <span> &middot; {new Date(entry.createdAt).toLocaleDateString()}</span>
        </div>

        {entry.status === 'failed' && entry.errorMessage ? (
          <div class="detail-section">
            <h2>Error</h2>
            <p style="color:var(--color-error);font-size:0.85rem;">{entry.errorMessage}</p>
            <form method="POST" action={`/api/entries/${entry.id}/enrich`} style="margin-top:0.75rem">
              <button type="submit">Retry enrichment</button>
            </form>
          </div>
        ) : null}

        {entry.description ? (
          <div class="detail-section">
            <h2>Description</h2>
            <p>{entry.description}</p>
          </div>
        ) : null}

        {entry.summary ? (
          <div class="detail-section">
            <h2>Summary</h2>
            <p>{entry.summary}</p>
          </div>
        ) : null}

        {entry.personalTags.length > 0 || entry.publicTags.length > 0 ? (
          <div class="detail-section">
            <h2>Tags</h2>
            <div class="tags">
              {entry.personalTags.map(tag => (
                <a href={`/tags/${tag}`} class="tag tag-personal">{tag}</a>
              ))}
              {entry.publicTags.map(tag => (
                <a href={`/tags/${tag}`} class="tag tag-public">{tag}</a>
              ))}
            </div>
          </div>
        ) : null}

        <div class="detail-section">
          <h2>Edit</h2>
          <form method="POST" action={`/api/entries/${entry.id}/edit`} class="edit-form">
            <label>
              Summary
              <textarea name="summary" rows="3">{entry.summary}</textarea>
            </label>
            <label>
              Personal tags (comma-separated)
              <input type="text" name="personalTags" value={entry.personalTags.join(', ')} />
            </label>
            <label>
              Public tags (comma-separated)
              <input type="text" name="publicTags" value={entry.publicTags.join(', ')} />
            </label>
            <button type="submit">Save changes</button>
          </form>
        </div>

        <div class="detail-actions">
        {Astro.url.searchParams.get('exported') ? (
          <p class="success-text" style="margin-top:1rem">Saved to Obsidian vault.</p>
        ) : null}
          <a href={entry.url} target="_blank" rel="noopener noreferrer">Open source &rarr;</a>
          <a href={`/api/entries/${entry.id}/markdown`} download>Download Markdown</a>
          <form method="POST" action={`/api/entries/${entry.id}/export-to-vault`} style="display:inline">
            <button type="submit">Save to Obsidian</button>
          </form>
          <form method="POST" action={`/api/entries/${entry.id}/delete`} style="display:inline" onsubmit="return confirm('Delete this entry?')">
            <button type="submit" class="btn-danger">Delete</button>
          </form>
          <a href="/">&larr; Back</a>
        </div>
      </div>
    </div>
  </body>
</html>
