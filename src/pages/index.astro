---
import { getRecentEntries, getEntryCount, searchEntries, getStats } from '../lib/db';
import BaseHead from '../components/BaseHead.astro';
import LinkForm from '../components/LinkForm.astro';
import SearchBox from '../components/SearchBox.astro';
import EntryCard from '../components/EntryCard.astro';
import Pagination from '../components/Pagination.astro';
import TagCloud from '../components/TagCloud.astro';
import '../styles/global.css';


const PAGE_SIZE = 20;
const query = Astro.url.searchParams.get('q') || '';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));

const stats = getStats();

let entries: ReturnType<typeof getRecentEntries>;
let totalEntries: number;
let totalPages: number;

if (query) {
  entries = searchEntries(query);
  totalEntries = entries.length;
  totalPages = 1;
} else {
  totalEntries = getEntryCount();
  totalPages = Math.max(1, Math.ceil(totalEntries / PAGE_SIZE));
  const offset = (page - 1) * PAGE_SIZE;
  entries = getRecentEntries(PAGE_SIZE, offset);
}
---

<html lang="en">
  <head>
    <BaseHead title="Link Curator" description="Save, enrich, search, and browse curated links." />
  </head>
  <body>
    <div class="container">
      <header class="app-header">
        <h1><a href="/">Link Curator</a></h1>
      </header>

      <LinkForm />
      <SearchBox />

      {query ? <p style="margin-bottom:0.75rem;font-size:0.85rem;color:var(--color-text-secondary);">Search results for: <strong>{query}</strong></p> : null}

      {entries.length === 0 ? (
        <div class="empty-state">
          {query ? <p>No results for "{query}"</p> : <p>No links yet. Paste a URL above to get started.</p>}
        </div>
      ) : (
        <>
          {entries.map(entry => <EntryCard entry={entry} />)}
          <Pagination page={page} totalPages={totalPages} baseUrl={query ? `/?q=${query}` : '/'} />
        </>
      )}

      {!query ? <TagCloud tags={stats.topTags} /> : null}
    </div>
  </body>
</html>
