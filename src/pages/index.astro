---
import { getRecentEntries, searchEntries } from '../lib/db';
import LinkForm from '../components/LinkForm.astro';
import SearchBox from '../components/SearchBox.astro';
import EntryCard from '../components/EntryCard.astro';
import '../styles/global.css';

const query = Astro.url.searchParams.get('q') || '';
const entries = query ? searchEntries(query) : getRecentEntries(50);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Link Curator</title>
  </head>
  <body>
    <div class="container">
      <header class="app-header">
        <h1><a href="/">Link Curator</a></h1>
      </header>

      <LinkForm />
      <SearchBox />

      {query ? <p style="margin-bottom:0.75rem;font-size:0.85rem;color:var(--color-text-secondary);">Search results for: <strong>{query}</strong></p> : null}

      {entries.length === 0 ? (
        <div class="empty-state">
          {query ? <p>No results for "{query}"</p> : <p>No links yet. Paste a URL above to get started.</p>}
        </div>
      ) : (
        entries.map(entry => <EntryCard entry={entry} />)
      )}
    </div>
  </body>
</html>
