---
import { getEntriesByTag } from '../../lib/db';
import BaseHead from '../../components/BaseHead.astro';
import Nav from '../../components/Nav.astro';
import EntryCard from '../../components/EntryCard.astro';
import '../../styles/global.css';

const { tag } = Astro.params;
const entries = tag ? getEntriesByTag(tag) : [];
---

<html lang="en">
  <head>
    <BaseHead title={`${tag} - Link Curator`} />
  </head>
  <body>
    <div class="container">
      <header class="app-header">
        <h1><a href="/">Link Curator</a></h1>
      </header>

      <Nav />

      <p style="margin-bottom:1rem">
        Tag: <strong>{tag}</strong> &middot; {entries.length} {entries.length === 1 ? 'entry' : 'entries'}
      </p>

      {entries.length === 0 ? (
        <div class="empty-state">
          <p>No entries tagged with "{tag}".</p>
          <p><a href="/">Back to home</a></p>
        </div>
      ) : (
        entries.map(entry => <EntryCard entry={entry} />)
      )}

      <p style="margin-top:1.5rem"><a href="/" class="back-link">&larr; Back to all entries</a></p>
    </div>
  </body>
</html>
